# Supabase Postgres (provided by the Supabase integration on Vercel)
# Pooled connection used by the Prisma Client at runtime
POSTGRES_PRISMA_URL="postgres://user:password@host:6543/postgres?pgbouncer=true"
# Direct (non-pooled) connection used for migrations / prisma db push
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/postgres"
