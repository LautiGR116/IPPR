{
  "name": "ippr-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:push": "sqlite3 prisma/dev.db \".read prisma/init.sql\"",
    "db:init": "npm run db:push && npm run db:seed",
    "db:seed": "tsx prisma/seed.ts",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "prisma": "^6.10.1",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3"
  }
}
